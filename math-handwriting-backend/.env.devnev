# Backend Development Environment Variables

# Server Configuration
HOST=0.0.0.0
PORT=8000
UVICORN_RELOAD=true

# CORS Configuration
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MongoDB Configuration
# For local development with Docker MongoDB
MONGODB_URL=mongodb://localhost:27017/math

# OR for MongoDB Atlas (uncomment and replace with your connection string)
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/math?retryWrites=true&w=majority
