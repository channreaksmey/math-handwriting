# Environment Variables Template
# Copy this file to .env.local and customize for your setup
# 
# IMPORTANT: .env.local is gitignored - safe for sensitive values
# For production, set these in your platform's environment variable settings

# MongoDB Connection (Required)
# Local MongoDB:
MONGODB_URL=mongodb://localhost:27017/math

# OR MongoDB Atlas:
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/math?retryWrites=true&w=majority

# CORS Configuration (Optional - defaults shown)
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ALLOW_ORIGIN_REGEX=

# Server Configuration (Optional - defaults shown)
# HOST=0.0.0.0
# PORT=8000
# UVICORN_RELOAD=false
